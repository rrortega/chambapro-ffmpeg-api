# Port where the server will listen (defaults to 8080)
PORT=8080

# Logging level (info, debug, warn, error)
RUST_LOG=info

# (Optional) API Key to secure the /convert and /convert-async endpoints. 
# If set, requests must include the 'X-API-KEY' header.
API_KEY=your_secret_api_key_here

# (Optional) Redis connection URL to enable background worker queueing.
# e.g., redis://127.0.0.1:6379 or redis://:password@host:6379/0
REDIS_URL=redis://127.0.0.1:6379

# (Optional) Max conversion retries in the Redis queue (defaults to 3)
MAX_RETRIES=3

# (Optional) Number of hours to keep converted files before cleanup (defaults to 24)
CLEANUP_HOURS=24

# (Optional) Storage folder for input/output files (defaults to ./storage)
STORAGE_DIR=./storage

# (Optional) Host URL used to construct webhook download links
HOST_URL=http://localhost:8080
